---
import PageHeader from "@/components/common/PageHeader.astro";
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/blog/PostCard.astro";

// Mock data for blog posts
const dummyPosts = [
  {
    title: "Hacking Astro with Bun",
    description: "A wild ride into Astro’s internals with Bun’s speed.",
    pubDate: "2025-03-16",
    url: "hacking-astro-with-bun",
    tags: ["astro", "bun", "oss"] as const,
    post: {
      render: async () => ({ remarkPluginFrontmatter: { readingTime: 5 } }),
    },
  },
  {
    title: "Open-Source Survival Guide",
    description: "Tips and tricks from a seasoned OSS contributor.",
    pubDate: "2025-03-14",
    url: "oss-survival-guide",
    tags: ["oss", "guide"] as const,
    post: {
      render: async () => ({ remarkPluginFrontmatter: { readingTime: 7 } }),
    },
  },
  {
    title: "Tailwind Hacks for Devs",
    description: "Unleashing Tailwind’s power for rapid prototyping.",
    pubDate: "2025-03-12",
    url: "tailwind-hacks",
    tags: ["tailwind", "dev"] as const,
    post: {
      render: async () => ({ remarkPluginFrontmatter: { readingTime: 4 } }),
    },
  },
  {
    title: "Mastering JavaScript",
    description: "Advanced techniques and patterns for JavaScript developers.",
    pubDate: "2025-03-10",
    url: "mastering-javascript",
    tags: ["javascript", "advanced"] as const,
    post: {
      render: async () => ({ remarkPluginFrontmatter: { readingTime: 6 } }),
    },
  },
  {
    title: "CSS Grid Layouts",
    description: "Creating complex layouts with CSS Grid.",
    pubDate: "2025-03-08",
    url: "css-grid-layouts",
    tags: ["css", "grid"] as const,
    post: {
      render: async () => ({ remarkPluginFrontmatter: { readingTime: 5 } }),
    },
  },
  {
    title: "CSS Grid Layouts",
    description: "Creating complex layouts with CSS Grid.",
    pubDate: "2025-03-08",
    url: "css-grid-layouts",
    tags: ["css", "grid"] as const,
    post: {
      render: async () => ({ remarkPluginFrontmatter: { readingTime: 5 } }),
    },
  },
] as const;
---

<Layout title="Mohammed's Blog | Posts">
  <section class="wrapper">
    <PageHeader
      title="🧑‍🚀 Latest Blog Posts !"
      subtitle="Explore the Cosmos of Ideas! Latest Blog Posts"
    />

    <!-- Blog Grid -->
    <!-- <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-8">
      {
        dummyPosts.map((post) => (
          <div class="h-full">
            <PostCard {...post} />
          </div>
        ))
      }
    </div> -->

    <!-- Blog Columns -->
    <div class="columns-1 md:columns-2 lg:columns-3 gap-6 mt-8">
      {
        dummyPosts.map((post) => (
          <div class="break-inside-avoid mb-6">
            <PostCard {...post} class="w-auto h-auto" />
          </div>
        ))
      }
    </div>

    <!-- Placeholder for Pagination/Search -->
    <div class="mt-12 text-center text-muted-foreground">
      More features coming soon...
    </div>
  </section>
</Layout>
