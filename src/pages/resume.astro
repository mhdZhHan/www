---
import Layout from "@/layouts/Layout.astro";
import Table from "@/components/common/Table.astro";
import SkillsList from "@/components/effects/SKillsList";

interface Tech {
  id: string;
  name: string;
  icon?: string;
}

interface EducationData {
  institute: string;
  link?: string;
  name: string;
  issued: string;
  location?: string;
}

interface ExperienceData {
  company: string;
  location?: string;
  role: string;
  duration: string;
  tasks: string[];
}

interface Row {
  data: EducationData | ExperienceData;
  isLastSibling?: boolean;
  groupId?: string | number;
}

interface ColumnSpec {
  id: string;
  name?: string;
  isExpanding?: boolean;
}

const educationColumns: ColumnSpec[] = [
  { id: "institute", name: "Institute", isExpanding: true },
  { id: "name", name: "Degree / Program", isExpanding: true },
  { id: "issued", name: "Duration" },
  { id: "location", name: "Location" },
];

const educationData: Row[] = [
  {
    data: {
      institute: "Indira Gandhi College of Arts and Science",
      name: "Bachelor of Computer Applications (BCA)",
      issued: "2021 – 2024",
      location: "Mahatma Gandhi University, Kottayam",
    },
    isLastSibling: false,
    groupId: "bca",
  },
  {
    data: {
      institute: "Indira Gandhi College of Arts and Science",
      name: "Artificial Intelligence and Machine Learning",
      issued: "2021 – 2024",
      location: "GITH - GLOBAL INDIA TECHNO HUB, Ernakulam",
    },
    isLastSibling: true,
    groupId: "ai-ml",
  },
];

const experienceColumns: ColumnSpec[] = [
  { id: "company", name: "Company", isExpanding: true },
  { id: "role", name: "Role" },
  { id: "duration", name: "Duration" },
  { id: "location", name: "Location" },
  { id: "tasks", name: "Responsibilities", isExpanding: true },
];

const experienceData: Row[] = [
  {
    data: {
      company: "IOTypes",
      location: "Remote",
      role: "Full Stack Developer",
      duration: "November 2024 – Present",
      tasks: [
        "Working on developing software as services solutions.",
        "Utilizing technologies such as Next.js, Drizzle ORM, PostgreSQL, and MySQL.",
        "Contributing to product-based solutions that help organizations be future-proof through data-driven solutions.",
      ],
    },
    isLastSibling: false,
    groupId: "iotypes",
  },
  {
    data: {
      company: "Steyp",
      location: "Kochi, Kerala, India",
      role: "Intern",
      duration: "2020 – 2023",
      tasks: [
        "Contributed to projects at Steyp, a startup incubated and accelerated by Talrop.",
        "Worked closely with cross-functional teams to develop innovative solutions.",
        "Gained hands-on experience in React.js, React Native, Express.js, MongoDB, and DevOps.",
      ],
    },
    isLastSibling: true,
    groupId: "steyp",
  },
];

const projectData = [
  {
    title: "Inkspire Blogging Platform",
    description: "A full-fledged blogging platform built with the MERN stack.",
    url: "https://inkspire-demo.com",
    githubUrl: "https://github.com/mhdZhHan/inkspire",
    tags: ["MERN", "Blogging"],
    technologies: [
      { id: "mongodb", name: "MongoDB", icon: "skill-icons:mongodb" },
      { id: "express", name: "Express.js", icon: "skill-icons:express-dark" },
      { id: "react", name: "React", icon: "skill-icons:react-dark" },
      { id: "nodejs", name: "Node.js", icon: "skill-icons:nodejs-dark" },
      { id: "aws", name: "AWS S3", icon: "skill-icons:aws-dark" },
    ],
  },
  {
    title: "Advanced MERN Authentication",
    description:
      "A secure authentication system with email verification and password reset.",
    url: "https://mern-auth-demo.com",
    githubUrl: "https://github.com/mhdZhHan/mern-auth",
    tags: ["MERN", "Authentication"],
    technologies: [
      { id: "mongodb", name: "MongoDB", icon: "skill-icons:mongodb" },
      { id: "express", name: "Express.js", icon: "skill-icons:express-dark" },
      { id: "react", name: "React", icon: "skill-icons:react-dark" },
      { id: "nodejs", name: "Node.js", icon: "skill-icons:nodejs-dark" },
      {
        id: "tailwind",
        name: "Tailwind CSS",
        icon: "skill-icons:tailwindcss-dark",
      },
    ],
  },
];
---

<Layout title="Mohammed Shajahan - Resume">
  <section class="wrapper max-w-4xl mx-auto py-12 font-serif">
    <!-- Header -->
    <div class="text-center border-b-2 border-muted pb-6 mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-foreground">
        Mohammed Shajahan
      </h1>
      <div
        class="mt-4 flex flex-wrap justify-center gap-2 text-muted-foreground text-sm"
      >
        <span>Kerala, India</span>
        <span>|</span>
        <span>+91 75618 28369</span>
        <span>|</span>
        <a href="mailto:hello.mohammedsh@gmail.com" class="hover:underline"
          >hello.mohammedsh@gmail.com</a
        >
        <span>|</span>
        <a
          href="https://mohammedsh.xyz"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:underline">mohammedsh.xyz</a
        >
        <span>|</span>
        <a
          href="https://linkedin.com/in/mohammedshajahan"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:underline">LinkedIn</a
        >
        <span>|</span>
        <a
          href="https://github.com/mhdZhHan"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:underline">GitHub</a
        >
      </div>
    </div>

    <!-- Summary -->
    <div class="mb-12">
      <h2 class="text-2xl font-semibold text-foreground mb-4">
        Full Stack Developer
      </h2>
      <p class="text-foreground text-base leading-relaxed">
        Skilled in MERN stack and Next.js, I build web and mobile apps that are
        efficient and user-friendly. Passionate about creating seamless user
        experiences and high-performance solutions. Let's connect and enhance
        the digital world together!
      </p>
    </div>

    <!-- Education -->
    <div class="mb-12">
      <h2
        class="text-2xl font-semibold text-foreground mb-4 border-b border-muted pb-2"
      >
        Education
      </h2>
      <Table columns={educationColumns} data={educationData} />
    </div>

    <!-- Experience -->
    <div class="mb-12">
      <h2
        class="text-2xl font-semibold text-foreground mb-4 border-b border-muted pb-2"
      >
        Experience
      </h2>
      <Table columns={experienceColumns} data={experienceData} />
    </div>

    <!-- Skills -->
    <div class="mb-12">
      <h2
        class="text-2xl font-semibold text-foreground mb-4 border-b border-muted pb-2"
      >
        Skills
      </h2>
      <SkillsList />
    </div>

    <!-- Projects -->
    <div>
      <h2
        class="text-2xl font-semibold text-foreground mb-4 border-b border-muted pb-2"
      >
        Project Works
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- {
          projectData.map((project) => (
            <ProjectCard
              title={project.title}
              description={project.description}
              url={project.url}
              githubUrl={project.githubUrl}
              tags={project.tags}
              technologies={project.technologies}
            />
          ))
        } -->
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Classic serif font for a traditional resume feel */
  .font-serif {
    font-family: "Georgia", "Times New Roman", serif;
  }

  /* Subtle hover effect for links */
  a:hover {
    color: var(--primary);
  }

  /* Ensure table headers and content align with classic style */
  :global(table th) {
    font-weight: 600;
    border-bottom: 1px solid var(--muted);
    padding-bottom: 0.5rem;
  }

  :global(table td) {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--muted);
  }

  /* Adjust SkillsList for classic feel */
  :global(.bg-[#1414149c]) {
    background-color: var(--background);
    border-color: var(--muted);
  }
</style>
