---
type Props = {
  title: string;
  subtitle: string;
};

const { title, subtitle } = Astro.props;
---

<div class="text-center space-y-3 mb-8">
  <h1 class="text-3xl sm:text-4xl font-bold text-foreground">
    {title}
  </h1>

  <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
    {subtitle}
  </p>
</div>
