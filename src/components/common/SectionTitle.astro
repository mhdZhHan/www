---
import { ArrowRight } from "lucide-astro";

type Props = {
  title: string;
  highlight: string;
  url: string;
};

const { title, highlight, url } = Astro.props;
---

<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
  <h2 class="text-2xl font-semibold text-foreground">
    {title}
    <span
      class="bg-clip-text text-transparent bg-gradient-to-r from-primary to-secondary relative"
    >
      {highlight}
      <span
        class="absolute bottom-0 left-0 w-full h-0.5 bg-primary/50 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"
      ></span>
    </span>
  </h2>

  <div class="text-right">
    <a
      href={url}
      class="group inline-flex items-center gap-1 text-base font-medium text-foreground hover:text-primary transition-colors duration-200"
      aria-label={`View all ${highlight}`}
    >
      View {highlight === "Posts" ? "All" : "More"}
      {highlight}
      <ArrowRight size={14} class="shrink-0" aria-hidden />
    </a>
  </div>
</div>
