---
type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Subscribe to my Newsletters",
  description = "Get the latest posts delivered right to your inbox.",
} = Astro.props;
---

<section class="wrapper">
  <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
    <!-- Left Side -->
    <div class="sm:w-7/12">
      <h3 class="text-2xl font-semibold text-foreground">
        {
          title
            .split(" ")
            .map((word, i) =>
              i === title.split(" ").length - 1 ? (
                <span class="bg-clip-text text-transparent bg-gradient-to-r from-primary to-secondary">
                  {word}
                </span>
              ) : (
                `${word} `
              ),
            )
        }
      </h3>
      <p class="mt-3 text-muted-foreground">{description}</p>
    </div>

    <!-- Right Side -->
    <div class="sm:w-5/12 w-full">
      <form action="">
        <div
          class="flex items-center w-full bg-secondary rounded-full p-2 border-2 border-border hover:border-primary transition-colors duration-200"
        >
          <input
            type="email"
            placeholder="Work Email"
            class="flex-1 bg-transparent outline-none text-foreground placeholder-muted-foreground px-2"
          />
          <button
            type="submit"
            class="px-3 py-1 bg-primary text-white font-medium text-sm rounded-full ml-2 shrink-0"
            aria-label="Submit newsletter"
          >
            Subscribe
          </button>
        </div>
      </form>
    </div>
  </div>
</section>
